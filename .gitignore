#.gitignore is used to prevent generated data files, Python cache files, and temporary Excel artifacts 
#from being committed to the repository, ensuring a clean and reproducible codebase.#
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.vscode/
.idea/

# Data
data/raw/
data/processed/
data/clean/daily/*.csv
!data/clean/install_dates.csv

# Exports
powerbi_exports/*.csv
!powerbi_exports/.gitkeep

# Virtual Environment
venv/
env/
ENV/